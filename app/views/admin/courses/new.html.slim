- cancel_path = admin_courses_path(anchor: dom_id(@course))

= simple_form_for [:admin, @course] do |form|
  .card.card-shadowed
    .card-header.d-flex.align-items-center.gap-2
      h5.mb-0 = "Neuen Kurs anlegen"
      .ms-auto
      = link_to cancel_path, class: "btn btn-link btn-sm" do
        i.fa-solid.fa-times
    .card-body
      = render "form_fields", form: form, course: @course
    .card-footer
      .d-flex.gap-2.flex-column.flex-md-row
        = form.submit t("admin.application.btn_save"), class: "btn btn-primary"
        = link_to t("admin.application.btn_cancel"), cancel_path, class: "btn btn-outline-secondary"
